---
import '../index.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  noindex?: boolean;
}

const {
  title = 'RevFactor — Intelligent Pricing for Inspired Stays',
  description = 'RevFactor delivers expert dynamic pricing strategy for short-term rental hosts — maximizing revenue without sacrificing control.',
  ogImage = '/og-image.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  noindex = false,
} = Astro.props;

const canonicalUrl = Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#13342D" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1"} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="RevFactor" />
  <meta property="og:locale" content="en_US" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {author && <meta property="article:author" content={author} />}

  <!-- Twitter Card — TODO: add @RevFactor handle to twitter:site/creator when account exists -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  <!-- Extra head content (schema, etc.) -->
  <slot name="head" />

  <!-- JS-detection: adds .js to <html> so opacity-0 GSAP targets are only hidden when JS runs.
       Without this, non-JS crawlers see all content at full opacity. -->
  <script is:inline>document.documentElement.classList.add('js')</script>

  <!-- Umami Analytics -->
  <script
    defer
    src="https://umami-rgc.up.railway.app/script.js"
    data-website-id="fd5982fb-76c6-4a8c-bf65-2ad69c72c306"
  ></script>

  <!-- Microsoft Clarity — session recording + heatmaps (free).
       Project ID env-overridable via PUBLIC_CLARITY_ID; default placeholder
       must be replaced with the real ID from https://clarity.microsoft.com
       (create a project for revfactor.io). The script self-skips if the ID
       is still the placeholder so we don't ship broken telemetry. -->
  <script is:inline define:vars={{ clarityId: import.meta.env.PUBLIC_CLARITY_ID || 'REPLACE_WITH_CLARITY_ID' }}>
    if (clarityId && clarityId !== 'REPLACE_WITH_CLARITY_ID') {
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        var y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", clarityId);
    }
  </script>

  <!-- Google Analytics + Google Ads (one gtag.js load handles both IDs) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-1CTGBJ9RLK"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-1CTGBJ9RLK');
    gtag('config', 'AW-18106897053');

    // Cal.com booking listener — fires Google Ads "Strategy Call Booked" conversion
    // and GA4 event when any embedded Cal.com iframe completes a booking.
    // Cal.com sends `{ type: 'bookingSuccessful', data: {...} }` via postMessage.
    (function () {
      var bookedThisSession = false;
      window.addEventListener('message', function (e) {
        if (!e.data || typeof e.data !== 'object') return;
        var type = e.data.type || (e.data.data && e.data.data.type);
        if (type !== 'bookingSuccessful' && type !== 'bookingSuccessfulV2') return;
        if (bookedThisSession) return;
        bookedThisSession = true;

        gtag('event', 'conversion', {
          send_to: 'AW-18106897053/WkHxCOKD46McEJ2lhbpD',
          value: 1500.00,
          currency: 'USD'
        });
        gtag('event', 'strategy_call_booked', {
          value: 1500,
          currency: 'USD',
          source: 'cal_com_embed'
        });
      });
    })();

    // Phone click listener — fires "Phone Click" conversion on tel: links.
    document.addEventListener('click', function (e) {
      var a = e.target && e.target.closest && e.target.closest('a[href^="tel:"]');
      if (!a) return;
      gtag('event', 'conversion', {
        send_to: 'AW-18106897053/eLI7CMiey6McEJ2lhbpD',
        value: 100.00,
        currency: 'USD'
      });
    });
  </script>
</head>
<body>
  <slot />
</body>
</html>
