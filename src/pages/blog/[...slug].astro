---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updatedDate = post.data.updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Article schema
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  "author": {
    "@type": "Organization",
    "name": post.data.author,
    "url": "https://revfactor.io"
  },
  "publisher": {
    "@type": "Organization",
    "name": "RevFactor",
    "url": "https://revfactor.io",
    "logo": {
      "@type": "ImageObject",
      "url": "https://revfactor.io/og-image.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  },
  "keywords": post.data.tags.join(', '),
  "articleSection": post.data.category
};
---

<BaseLayout
  title={`${post.data.title} — RevFactor`}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={(post.data.updatedDate ?? post.data.pubDate).toISOString()}
  author={post.data.author}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- Minimal nav -->
  <nav
    class="fixed top-4 left-1/2 -translate-x-1/2 z-50 px-3 py-2.5 rounded-full flex items-center gap-1 bg-[#DDDAD3]/60 backdrop-blur-[12px] border border-[#CCC8BF]/40 shadow-[0_4px_12px_rgba(22,25,16,0.08)]"
  >
    <a
      href="/"
      class="text-[22px] font-normal tracking-[0.5px] px-3 text-[#3F261F]"
      style="font-family: 'Cormorant Garamond', Georgia, serif;"
    >
      revfactor
    </a>
    <a
      href="/blog"
      class="hidden md:inline-flex items-center gap-2 ml-2 px-4 py-1.5 border border-[#3F261F]/20 text-[#3F261F] font-bold uppercase text-[9px] tracking-[2px] rounded-full hover:bg-[#3F261F]/5 transition-colors"
    >
      ← journal
    </a>
  </nav>

  <main class="min-h-screen bg-[#DDDAD3]">
    <!-- Article Header -->
    <header class="pt-32 md:pt-40 pb-12 md:pb-16">
      <div class="max-w-3xl mx-auto px-6 md:px-12">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-[2px] text-[#8F6E62]">
            <li><a href="/" class="hover:text-[#3F261F] transition-colors">Home</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li><a href="/blog" class="hover:text-[#3F261F] transition-colors">Journal</a></li>
            <li aria-hidden="true" class="opacity-40">/</li>
            <li aria-current="page" class="text-[#3F261F] truncate max-w-[200px]">{post.data.title}</li>
          </ol>
        </nav>

        <!-- Category -->
        <span class="inline-block px-3 py-1.5 rounded-full bg-[#5D6D59]/10 text-[#5D6D59] font-bold uppercase text-[9px] tracking-[2px] mb-6">
          {post.data.category}
        </span>

        <!-- Title -->
        <h1
          class="text-[clamp(28px,5vw,52px)] leading-[1.1] text-[#3F261F] mb-5"
          style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; letter-spacing: 0.5px;"
        >
          {post.data.title}
        </h1>

        <!-- Description -->
        <p class="text-[16px] leading-[1.7] text-[#76574C] mb-8">
          {post.data.description}
        </p>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 pb-8 border-b border-[#CCC8BF]/40">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-[#13342D] flex items-center justify-center">
              <span class="text-[10px] text-[#E8E6E1] font-bold">RF</span>
            </div>
            <span class="text-[13px] text-[#76574C] font-medium">{post.data.author}</span>
          </div>
          <time
            datetime={post.data.pubDate.toISOString()}
            class="text-[12px] font-bold uppercase tracking-[1.5px] text-[#8F6E62]"
          >
            {formattedDate}
          </time>
          {updatedDate && (
            <span class="text-[12px] text-[#8F6E62]">Updated {updatedDate}</span>
          )}
          {post.data.readingTime && (
            <span class="text-[12px] text-[#8F6E62]">{post.data.readingTime} min read</span>
          )}
        </div>
      </div>
    </header>

    <!-- Article Body -->
    <div class="max-w-3xl mx-auto px-6 md:px-12 pb-24">
      <!-- Table of Contents (if headings exist) -->
      {headings.length > 1 && (
        <aside class="mb-10 p-6 bg-[#E8E6E1] rounded-[12px]" style="box-shadow: 0 1px 3px rgba(22,25,16,0.06);">
          <p class="font-bold uppercase text-[9px] tracking-[2.5px] text-[#8F6E62] mb-3">IN THIS ARTICLE</p>
          <nav aria-label="Table of contents">
            <ol class="space-y-1.5">
              {headings.filter(h => h.depth <= 2).map((heading) => (
                <li>
                  <a
                    href={`#${heading.slug}`}
                    class={`text-[13px] text-[#76574C] hover:text-[#13342D] transition-colors leading-[1.5] ${heading.depth === 2 ? 'pl-0' : 'pl-4'}`}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

      <!-- Prose content -->
      <article class="prose-rf">
        <Content />
      </article>

      <!-- Tags -->
      {post.data.tags.length > 0 && (
        <div class="mt-12 pt-8 border-t border-[#CCC8BF]/40">
          <p class="font-bold uppercase text-[9px] tracking-[2.5px] text-[#8F6E62] mb-3">TOPICS</p>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-3 py-1 bg-[#E8E6E1] text-[#76574C] text-[12px] rounded-full border border-[#CCC8BF]/40">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- CTA -->
      <div
        class="mt-16 p-8 md:p-10 bg-[#13342D] rounded-[20px] text-center"
      >
        <p class="font-bold uppercase text-[9px] tracking-[3px] text-[#7A8B76] mb-4">
          READY TO OPTIMIZE YOUR REVENUE?
        </p>
        <h2
          class="text-[clamp(22px,3.5vw,32px)] leading-[1.2] text-[#E8E6E1] mb-4"
          style="font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400;"
        >
          Let's talk about your{' '}
          <em style="font-style: italic; color: #7A8B76;">properties</em>
        </h2>
        <p class="text-[14px] leading-[1.7] text-[#CCC8BF] mb-7 max-w-md mx-auto">
          Schedule a free 30-minute discovery call to see what expert revenue management could do for your STR portfolio.
        </p>
        <a
          href="/review"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-[#E8E6E1] text-[#13342D] font-bold uppercase text-[10px] tracking-[2px] rounded-full hover:bg-white transition-colors duration-200"
        >
          schedule a strategy call →
        </a>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-[#161910] py-8">
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-[11px] text-[#8F6E62]/50">
        &copy; 2025 RevFactor. Past performance is not indicative of future results.
      </p>
      <p class="text-[11px] text-[#8F6E62]/30">Precision revenue craft.</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Blog prose styles — scoped to this page */
  .prose-rf :global(h2) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.2;
    color: #3F261F;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: 0.3px;
  }
  .prose-rf :global(h3) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
    font-size: clamp(18px, 2.5vw, 24px);
    color: #3F261F;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-rf :global(p) {
    font-size: 15px;
    line-height: 1.75;
    color: #76574C;
    margin-bottom: 1.25rem;
  }
  .prose-rf :global(ul),
  .prose-rf :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }
  .prose-rf :global(li) {
    font-size: 15px;
    line-height: 1.7;
    color: #76574C;
    margin-bottom: 0.5rem;
  }
  .prose-rf :global(strong) {
    color: #3F261F;
    font-weight: 600;
  }
  .prose-rf :global(a) {
    color: #13342D;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-rf :global(a:hover) {
    color: #1E4A40;
  }
  .prose-rf :global(blockquote) {
    border-left: 3px solid #5D6D59;
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    background: #E8E6E1;
    border-radius: 0 8px 8px 0;
  }
  .prose-rf :global(blockquote p) {
    margin: 0;
    font-style: italic;
    color: #3F261F;
  }
  .prose-rf :global(hr) {
    border: none;
    border-top: 1px solid #CCC8BF;
    margin: 2rem 0;
  }
  .prose-rf :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    background: #E8E6E1;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: #13342D;
  }
</style>
