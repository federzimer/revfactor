---
import BaseLayout from '../layouts/BaseLayout.astro';
import PPCNavbar from '../components/PPCNavbar.jsx';
import PPCLanding from '../components/PPCLanding.jsx';

const comparisonRows = [
  { label: "Sets daily price points", tool: true },
  { label: "Comp set benchmarking", tool: true },
  { label: "Calendar-aware demand modeling", tool: true },
  { label: "Strategic positioning vs. comp set", tool: false },
  { label: "Length-of-stay rules tuned to your market", tool: false },
  { label: "Minimum-night strategy across seasons", tool: false },
  { label: "Listing copy + photo audit", tool: false },
  { label: "Monthly strategy call with a real human", tool: false },
  { label: "Custom playbook for events, holidays, shoulder season", tool: false },
];

const faqs = [
  {
    q: "Do I have to switch pricing tools?",
    a: "No. RevFactor works on top of whatever pricing tool you already use — PriceLabs, Wheelhouse, Beyond Pricing, or none. We calibrate the algorithm and layer strategy on top of it.",
  },
  {
    q: "How is this different from a pricing tool?",
    a: "Pricing tools set numbers based on data. We set strategy based on context — market shifts, listing positioning, channel mix, seasonality, your portfolio's specific revenue goals. Tools alone leave money on the table.",
  },
  {
    q: "What's the actual revenue lift?",
    a: "Documented +18% average vs. comp set across our portfolio. Top performers see +20% (Kassidy & Erin Warren) to +75% (Kate Henry) year-over-year.",
  },
  {
    q: "How does pricing work?",
    a: "Flat $320/month per property. No percent-of-revenue gotchas, no setup fees. Volume discounts kick in past 5 properties.",
  },
  {
    q: "How fast can we get started?",
    a: "Strategy call within 48 hours of booking. If we're a fit, onboarding takes about a week. You see comp-set benchmarks on day one.",
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.revfactor.io/" },
    { "@type": "ListItem", "position": 2, "name": "Airbnb Pricing Strategy", "item": "https://www.revfactor.io/airbnb-pricing-strategy" },
  ],
};
---

<BaseLayout
  title="Airbnb Pricing Strategy — Beyond Auto-Pricing | RevFactor"
  description="A pricing tool sets prices. RevFactor sets the strategy that makes them work. +18% revenue lift vs. comp set. Flat $320/mo per property."
  noindex={true}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <PPCNavbar client:load />
  <main>
    <PPCLanding
      client:load
      eyebrow="AIRBNB PRICING STRATEGY"
      headlinePart1="Pricing tools set the price."
      headlinePart2Italic="We set the strategy."
      subhead="A pricing tool tells you what to charge tonight. RevFactor builds the strategy that makes the price work — comp positioning, length-of-stay rules, listing audits, monthly recalibration. The result: +18% revenue lift vs. comp set."
      ctaText="Schedule a free 30-min call"
      comparisonRows={comparisonRows}
      faqs={faqs}
      finalCtaPretext="STILL OUT-PRICED BY THE COMP SET?"
    />
  </main>
</BaseLayout>
