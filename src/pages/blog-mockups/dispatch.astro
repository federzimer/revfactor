---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';

const categorySlider = [
  { name: 'Revenue Basics',   count: 14, accent: '#5D6D59', description: 'ADR, RevPAR, pacing, and the fundamentals nobody teaches.', icon: 'M3 3v18h18' },
  { name: 'Pricing Strategy', count: 22, accent: '#13342D', description: 'Dynamic pricing, seasonality, event-aware rates.', icon: 'M12 2v20M2 12h20' },
  { name: 'Tools & PMS',      count: 11, accent: '#76574C', description: 'PriceLabs, Hospitable, OwnerRez, Hostaway — honest reviews.', icon: 'M6 2h12l4 7-10 13L2 9z' },
  { name: 'Launch Playbook',   count: 9,  accent: '#3F261F', description: 'Zero-to-booked in 60 days. Market penetration pricing.', icon: 'M5 12l5 5L20 7' },
  { name: 'Client Results',    count: 12, accent: '#5D6D59', description: 'Real portfolios, real numbers, real case studies.', icon: 'M22 11.08V12a10 10 0 1 1-5.93-9.14' },
  { name: 'Market Data',       count: 8,  accent: '#13342D', description: 'Occupancy by city, ADR trends, booking window analysis.', icon: 'M8 3v18M16 3v18M3 8h18M3 16h18' },
  { name: 'Market Guides',     count: 6,  accent: '#76574C', description: '56 markets, 24 states — location-specific pricing.', icon: 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z' },
  { name: 'Yield Management',  count: 7,  accent: '#3F261F', description: 'Airline yield principles applied to short-term rentals.', icon: 'M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z' },
  { name: 'Industry News',     count: 5,  accent: '#5D6D59', description: 'Airbnb algorithm changes, OTA policy, regulation tracking.', icon: 'M4 22V2l8 4 8-4v20M4 6l8 4 8-4' },
];

const tickerItems = [
  { label: 'Smokies ADR', value: '$312', delta: '+4.2%' },
  { label: 'Gatlinburg Occ.', value: '71%', delta: '+1.8pt' },
  { label: 'Myrtle Beach ADR', value: '$248', delta: '-2.1%' },
  { label: 'Poconos RevPAR', value: '$186', delta: '+6.4%' },
  { label: 'Tucson Occ.', value: '64%', delta: '+3.0pt' },
  { label: 'Tahoe ADR', value: '$512', delta: '+8.7%' },
  { label: 'Sedona RevPAR', value: '$284', delta: '+1.2%' },
];

const latestPosts = [
  { cat: 'Pricing Strategy', date: 'Apr 18, 2026', read: '9 min', title: 'The rate elasticity map of the Smoky Mountains', excerpt: 'A season of 14,000 bookings, plotted. How sensitive are guests to a $25 swing.', featured: true, img: 'https://images.unsplash.com/photo-1502784444187-359ac186c5bb?auto=format&fit=crop&w=1600&q=85' },
  { cat: 'Revenue Basics',   date: 'Apr 12, 2026', read: '7 min',  title: 'The quiet math of midweek shoulder season' },
  { cat: 'Market Data',      date: 'Apr 05, 2026', read: '11 min', title: 'Q1 2026: the great flattening of ADR across tier-two markets' },
  { cat: 'Tools & PMS',      date: 'Mar 28, 2026', read: '6 min',  title: 'What we learned shipping the Hostaway connector' },
  { cat: 'Client Results',   date: 'Mar 19, 2026', read: '8 min',  title: 'How Blueridge Retreats added $184K in 11 months' },
  { cat: 'Tools & PMS',      date: 'Mar 11, 2026', read: '5 min',  title: "Pacing Tool v3: what's new, what's gone" },
];

const trendingPosts = [
  { cat: 'Pricing Strategy', date: 'Feb 24, 2026', read: '7 min',  title: "Pricing for events you didn't know were happening" },
  { cat: 'Market Data',      date: 'Feb 15, 2026', read: '6 min',  title: 'ADR vs. occupancy: stop choosing' },
  { cat: 'Client Results',   date: 'Feb 02, 2026', read: '9 min',  title: 'Mountain Valley Lodges: 18 months on dynamic pricing' },
  { cat: 'Yield Management', date: 'Jan 26, 2026', read: '7 min',  title: "The booking window is closing. Here's what it means." },
];

const editorPicks = [
  { cat: 'Launch Playbook',  date: 'Jan 19, 2026', read: '14 min', title: "The first 60 days: a new listing's pricing playbook" },
  { cat: 'Yield Management', date: 'Jan 12, 2026', read: '12 min', title: 'Why your pricing app is wrong about weekends' },
  { cat: 'Revenue Basics',   date: 'Jan 05, 2026', read: '8 min',  title: 'The three metrics every host should watch daily' },
];
---

<BaseLayout
  title="The Dispatch — RevFactor Journal"
  description="The RevFactor Dispatch — weekly field notes on STR pricing, markets, and operator tactics."
>
  <Navbar client:load />

  <!-- LIVE TICKER (always at top, below nav) -->
  <div class="bg-[#161910] text-[#E8E6E1] border-b border-[#E8E6E1]/5 pt-20 md:pt-24">
    <div class="relative overflow-hidden">
      <div class="flex items-center gap-2 py-3 px-6 md:px-12">
        <span class="flex-shrink-0 px-2.5 py-1 rounded-full bg-[#5D6D59]/20 text-[#7A8B76] font-bold uppercase text-[8.5px] tracking-[2px] flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#7A8B76]" style="animation:pulse-dot 2s ease-in-out infinite;"></span>
          live market ticker
        </span>
        <div class="flex-1 overflow-hidden relative">
          <div class="flex gap-10 whitespace-nowrap animate-ticker" style="animation: ticker 60s linear infinite;">
            {[...tickerItems, ...tickerItems].map(t => (
              <span class="inline-flex items-center gap-2 text-[11.5px]" style="font-family:'JetBrains Mono',monospace;">
                <span class="text-[#DDDAD3]/50 uppercase tracking-[0.5px]">{t.label}</span>
                <span class="text-[#E8E6E1] font-medium">{t.value}</span>
                <span class:list={[t.delta.startsWith('+') ? 'text-[#7A8B76]' : 'text-[#B87F6E]']}>{t.delta}</span>
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <main class="bg-[#DDDAD3]">

    <!-- MASTHEAD — newspaper-inspired -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 pt-16 pb-8 border-b-2 border-[#3F261F]">
      <div class="flex items-center justify-between mb-6 text-[10px] font-bold uppercase tracking-[2.5px] text-[#8F6E62]">
        <span>Vol. 3 · Issue 12</span>
        <span class="hidden md:inline">Thursday, April 23, 2026 · Published Weekly</span>
        <span>Est. 2024 · RevFactor.io</span>
      </div>
      <h1 class="text-[#3F261F] leading-[0.88] text-center mb-4" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(72px,14vw,192px); letter-spacing:-3px;">
        The <em style="font-style:italic; color:#13342D;">Dispatch</em>
      </h1>
      <p class="text-center text-[#76574C] max-w-2xl mx-auto" style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-weight:300; font-size:clamp(16px,1.6vw,20px); line-height:1.4;">
        A weekly field report on pricing, pacing, and yield — for operators who care about the curve.
      </p>
      <div class="flex items-center justify-center gap-8 mt-8 flex-wrap">
        <div class="text-center"><div class="text-[22px] text-[#13342D]" style="font-family:'JetBrains Mono',monospace; font-weight:500;">84</div><div class="font-bold uppercase text-[8.5px] tracking-[2px] text-[#8F6E62]">Essays</div></div>
        <div class="w-px h-10 bg-[#C8C4BC]"></div>
        <div class="text-center"><div class="text-[22px] text-[#13342D]" style="font-family:'JetBrains Mono',monospace; font-weight:500;">12.4k</div><div class="font-bold uppercase text-[8.5px] tracking-[2px] text-[#8F6E62]">Subscribers</div></div>
        <div class="w-px h-10 bg-[#C8C4BC]"></div>
        <div class="text-center"><div class="text-[22px] text-[#13342D]" style="font-family:'JetBrains Mono',monospace; font-weight:500;">$4.2M</div><div class="font-bold uppercase text-[8.5px] tracking-[2px] text-[#8F6E62]">Revenue influenced</div></div>
      </div>
    </section>

    <!-- CATEGORY UX: INTERACTIVE CARD SLIDER -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 py-12">
      <div class="flex items-end justify-between mb-6 gap-4 flex-wrap">
        <div>
          <span class="font-bold uppercase text-[9px] tracking-[3px] text-[#8F6E62] block mb-2">Browse by desk</span>
          <h2 class="text-[#3F261F] leading-[1]" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(28px,3.5vw,40px);">Nine desks, one newsroom.</h2>
        </div>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2 px-4 py-2 rounded-full border border-[#C8C4BC] bg-white/40">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#76574C" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            <input id="search" type="search" placeholder="Search the dispatch…" class="bg-transparent text-[13px] text-[#3F261F] placeholder:text-[#8F6E62] outline-none w-40" />
          </label>
          <button id="slidePrev" class="w-10 h-10 rounded-full border border-[#C8C4BC] bg-white/40 hover:bg-white/70 flex items-center justify-center transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3F261F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button id="slideNext" class="w-10 h-10 rounded-full border border-[#C8C4BC] bg-white/40 hover:bg-white/70 flex items-center justify-center transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3F261F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <div id="catSlider" class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 scrollbar-thin" style="scroll-behavior:smooth;">
        <button
          data-cat="All"
          class="cat-card snap-start flex-shrink-0 w-[180px] md:w-[220px] p-5 rounded-[16px] border text-left transition-all duration-[350ms] bg-[#13342D] text-[#E8E6E1] border-[#13342D]"
          style="transition-timing-function:cubic-bezier(0.25,0.1,0.25,1);"
        >
          <div class="flex items-center justify-between mb-4">
            <div class="w-10 h-10 rounded-full bg-[#E8E6E1]/10 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            </div>
            <span class="text-[28px]" style="font-family:'JetBrains Mono',monospace; font-weight:500;">84</span>
          </div>
          <h3 class="text-[20px] leading-[1.1] mb-1.5" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">All desks</h3>
          <p class="text-[12px] leading-[1.5] text-[#DDDAD3]/75">The full archive — every essay we've ever published.</p>
        </button>

        {categorySlider.map(c => (
          <button
            data-cat={c.name}
            class="cat-card snap-start flex-shrink-0 w-[180px] md:w-[220px] p-5 rounded-[16px] border bg-[#E8E6E1] border-[#C8C4BC] text-[#3F261F] text-left transition-all duration-[350ms] hover:-translate-y-1 hover:shadow-[0_12px_24px_rgba(22,25,16,0.08)]"
            style="transition-timing-function:cubic-bezier(0.25,0.1,0.25,1);"
          >
            <div class="flex items-center justify-between mb-4">
              <div class="w-10 h-10 rounded-full flex items-center justify-center" style={`background-color:${c.accent}1A; color:${c.accent};`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon}/></svg>
              </div>
              <span class="text-[28px]" style={`font-family:'JetBrains Mono',monospace; font-weight:500; color:${c.accent};`}>{c.count}</span>
            </div>
            <h3 class="text-[20px] leading-[1.1] mb-1.5" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">{c.name}</h3>
            <p class="text-[12px] leading-[1.5] text-[#76574C]">{c.description}</p>
          </button>
        ))}
      </div>
    </section>

    <!-- TABBED FEED -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24">
      <div class="flex items-center gap-2 mb-10 border-b border-[#C8C4BC]">
        {['Latest', 'Trending', "Editor's picks"].map((tab, i) => (
          <button
            class:list={['tab-btn px-5 py-4 font-bold uppercase text-[10.5px] tracking-[2.5px] transition-colors border-b-2 -mb-px', i === 0 ? 'text-[#3F261F] border-[#13342D]' : 'text-[#8F6E62] border-transparent hover:text-[#3F261F]']}
            data-tab={tab.toLowerCase().replace(/[^a-z]/g, '')}
          >{tab}</button>
        ))}
        <div class="ml-auto font-bold uppercase text-[9px] tracking-[2px] text-[#8F6E62] flex items-center gap-2" id="activeFilter">
          <span class="w-1.5 h-1.5 rounded-full bg-[#5D6D59]"></span>
          Showing: <span class="text-[#3F261F]" id="activeCat">All desks</span>
        </div>
      </div>

      <!-- LATEST TAB: featured + column list -->
      <div class="tab-panel grid grid-cols-1 md:grid-cols-[1.3fr_1fr] gap-10" data-panel="latest">
        <!-- Featured item -->
        <a href="#" data-cat={latestPosts[0].cat} class="post-card block group">
          <div class="relative overflow-hidden rounded-[16px] mb-5" style="aspect-ratio:16/10;">
            <img src={latestPosts[0].img} alt="" class="w-full h-full object-cover transition-transform duration-[600ms] group-hover:scale-[1.04]"/>
            <span class="absolute top-4 left-4 z-[2] px-2.5 py-1 rounded-full bg-[#E8E6E1]/92 text-[#3F261F] font-bold uppercase text-[9px] tracking-[2px] backdrop-blur-sm">{latestPosts[0].cat}</span>
            <span class="absolute top-4 right-4 z-[2] px-2.5 py-1 rounded-full bg-[#13342D] text-[#E8E6E1] font-bold uppercase text-[9px] tracking-[2px]">● Live read</span>
          </div>
          <div class="flex items-center gap-3 text-[11px] font-bold uppercase tracking-[1.5px] text-[#8F6E62] mb-3">
            <span>{latestPosts[0].date}</span><span>·</span><span>{latestPosts[0].read}</span>
          </div>
          <h2 class="leading-[1.05] mb-4 text-[#3F261F] group-hover:text-[#13342D] transition-colors" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(30px,3.5vw,48px);">{latestPosts[0].title}</h2>
          <p class="text-[15px] leading-[1.7] text-[#76574C]">{latestPosts[0].excerpt}</p>
          <div class="flex items-center gap-3 mt-6">
            <div class="w-10 h-10 rounded-full bg-[#C8C4BC] flex items-center justify-center text-[#3F261F] font-bold text-[12px]" style="font-family:'Cormorant Garamond',Georgia,serif;">FZ</div>
            <div>
              <div class="font-bold uppercase text-[9px] tracking-[2px] text-[#3F261F]">Federico Zimerman</div>
              <div class="text-[12px] text-[#8F6E62]">Founder · RevFactor</div>
            </div>
          </div>
        </a>

        <!-- Column list -->
        <div class="flex flex-col divide-y divide-[#C8C4BC]">
          {latestPosts.slice(1).map((p, i) => (
            <a href="#" data-cat={p.cat} class="post-card group py-6 first:pt-0 last:pb-0 flex items-start gap-5">
              <div class="text-[32px] text-[#C8C4BC] leading-none flex-shrink-0 w-12" style="font-family:'JetBrains Mono',monospace; font-weight:500;">
                {String(i + 2).padStart(2, '0')}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 text-[10.5px] font-bold uppercase tracking-[2px] mb-2">
                  <span class="text-[#5D6D59]">{p.cat}</span>
                  <span class="text-[#C8C4BC]">·</span>
                  <span class="text-[#8F6E62]">{p.date}</span>
                  <span class="text-[#C8C4BC]">·</span>
                  <span class="text-[#8F6E62]">{p.read}</span>
                </div>
                <h3 class="text-[20px] md:text-[22px] leading-[1.2] text-[#3F261F] group-hover:text-[#13342D] transition-colors" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">{p.title}</h3>
              </div>
              <svg class="flex-shrink-0 mt-2 text-[#C8C4BC] group-hover:text-[#13342D] transition-colors" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- TRENDING TAB -->
      <div class="tab-panel hidden grid-cols-1 md:grid-cols-3 gap-8" data-panel="trending">
        {trendingPosts.map((p, i) => (
          <a href="#" data-cat={p.cat} class="post-card group block">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-[11px] text-[#C8C4BC]" style="font-family:'JetBrains Mono',monospace; font-weight:500;">#{i + 1}</span>
              <span class="text-[10.5px] font-bold uppercase tracking-[2px] text-[#5D6D59]">{p.cat}</span>
            </div>
            <h3 class="text-[24px] md:text-[26px] leading-[1.15] text-[#3F261F] group-hover:text-[#13342D] transition-colors mb-3" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">{p.title}</h3>
            <div class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-[1.5px] text-[#8F6E62]">
              <span>{p.date}</span><span>·</span><span>{p.read}</span>
            </div>
          </a>
        ))}
      </div>

      <!-- EDITOR'S PICKS TAB -->
      <div class="tab-panel hidden" data-panel="editorspicks">
        <div class="flex flex-col divide-y divide-[#C8C4BC]">
          {editorPicks.map((p, i) => (
            <a href="#" data-cat={p.cat} class="post-card group py-8 first:pt-0 flex items-center gap-8 flex-wrap">
              <div class="w-14 h-14 rounded-full bg-[#13342D] text-[#E8E6E1] flex items-center justify-center flex-shrink-0" style="font-family:'Cormorant Garamond',Georgia,serif;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 text-[10.5px] font-bold uppercase tracking-[2px] mb-2">
                  <span class="text-[#5D6D59]">{p.cat}</span>
                  <span class="text-[#C8C4BC]">·</span>
                  <span class="text-[#8F6E62]">{p.date}</span>
                  <span class="text-[#C8C4BC]">·</span>
                  <span class="text-[#8F6E62]">{p.read}</span>
                </div>
                <h3 class="text-[28px] md:text-[32px] leading-[1.1] text-[#3F261F] group-hover:text-[#13342D] transition-colors" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">{p.title}</h3>
              </div>
              <svg class="text-[#C8C4BC] group-hover:text-[#13342D] transition-colors" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- THIS WEEK IN PRICING — live data widget -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24">
      <div class="rounded-[20px] bg-[#13342D] text-[#E8E6E1] p-8 md:p-14">
        <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
          <div>
            <span class="font-bold uppercase text-[9px] tracking-[2.5px] text-[#A9BBA3] mb-2 inline-block">This week in pricing</span>
            <h3 class="leading-[1.1]" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(28px,3.5vw,44px);">The market, at a glance.</h3>
          </div>
          <span class="font-bold uppercase text-[9px] tracking-[2px] text-[#A9BBA3] flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-[#7A8B76]" style="animation:pulse-dot 2s ease-in-out infinite;"></span>
            Updated {new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
          </span>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {[
            ['+18%', 'Revenue vs. comp set', 'RevFactor clients, Q1 2026'],
            ['72%', 'Avg. occupancy', '165 properties, last 30d'],
            ['$312', 'Smokies avg ADR', '+4.2% WoW'],
            ['$184K', 'Lift captured', 'Blueridge, 11 months'],
          ].map(([num, label, sub]) => (
            <div class="bg-[#E8E6E1]/5 rounded-[14px] p-6 border border-[#E8E6E1]/10">
              <div class="text-[#E8E6E1] leading-none mb-3" style="font-family:'JetBrains Mono',monospace; font-weight:500; font-size:clamp(28px,3.5vw,40px);">{num}</div>
              <div class="font-bold uppercase text-[9px] tracking-[2px] text-[#A9BBA3] mb-1">{label}</div>
              <div class="text-[12px] text-[#DDDAD3]/65" style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-weight:300;">{sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24">
      <div class="rounded-[20px] bg-[#161910] text-[#E8E6E1] px-8 md:px-16 py-16 md:py-20 text-center">
        <span class="font-bold uppercase text-[9px] tracking-[2.5px] text-[#DDDAD3]/80 mb-5 inline-block">Delivered Thursdays</span>
        <h3 class="leading-[1.1] mb-4" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(28px,3.5vw,44px);">
          The Dispatch, in your inbox.<br/><em style="font-style:italic; color:#A9BBA3; font-weight:300;">One essay, one chart, one decision.</em>
        </h3>
        <p class="text-[15px] leading-[1.6] text-[#DDDAD3]/70 max-w-xl mx-auto mb-8">
          Pricing strategy, market moves, and operator field notes. No fluff, no product pitches.
        </p>
        <form class="flex flex-col sm:flex-row gap-2 max-w-md mx-auto" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Subscribed ✓';">
          <input type="email" placeholder="you@cabin.co" required class="flex-1 px-5 py-3 rounded-full bg-[#E8E6E1]/10 border border-[#E8E6E1]/20 text-[14px] text-[#E8E6E1] placeholder:text-[#DDDAD3]/50 outline-none" />
          <button type="submit" class="px-6 py-3 rounded-full bg-[#E8E6E1] text-[#161910] font-bold uppercase text-[10px] tracking-[2px] hover:scale-[1.02] transition-transform">Subscribe</button>
        </form>
        <div class="text-[11px] text-[#DDDAD3]/50 mt-5">12,400 operators · unsubscribe anytime</div>
      </div>
    </section>
  </main>

  <Footer client:load />

  <!-- Mockup switcher -->
  <div class="fixed bottom-6 right-6 z-[60] bg-[#161910] text-[#E8E6E1] rounded-full px-2 py-1.5 flex items-center gap-1 shadow-xl text-[11px]">
    <span class="px-2 text-[#DDDAD3]/60 uppercase tracking-[1.5px] font-bold text-[9px]">Layout</span>
    <a href="/journal" class="px-3 py-1.5 rounded-full hover:bg-[#E8E6E1]/10 font-bold uppercase text-[9px] tracking-[1.5px]">01 Journal</a>
    <a href="/blog-mockups/masonry" class="px-3 py-1.5 rounded-full hover:bg-[#E8E6E1]/10 font-bold uppercase text-[9px] tracking-[1.5px]">02 Masonry</a>
    <a href="/blog-mockups/overlay" class="px-3 py-1.5 rounded-full hover:bg-[#E8E6E1]/10 font-bold uppercase text-[9px] tracking-[1.5px]">03 Overlay</a>
    <a href="/blog-mockups/dispatch" class="px-3 py-1.5 rounded-full bg-[#E8E6E1] text-[#161910] font-bold uppercase text-[9px] tracking-[1.5px]">04 Dispatch</a>
  </div>

  <style>
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    #catSlider::-webkit-scrollbar { height: 4px; }
    #catSlider::-webkit-scrollbar-track { background: transparent; }
    #catSlider::-webkit-scrollbar-thumb { background: #C8C4BC; border-radius: 2px; }
  </style>

  <script>
    // Category slider arrows
    const slider = document.getElementById('catSlider');
    document.getElementById('slidePrev')?.addEventListener('click', () => slider?.scrollBy({ left: -300, behavior: 'smooth' }));
    document.getElementById('slideNext')?.addEventListener('click', () => slider?.scrollBy({ left: 300, behavior: 'smooth' }));

    // Category card selection
    const catCards = document.querySelectorAll('.cat-card');
    const activeCatEl = document.getElementById('activeCat');
    const searchEl = document.getElementById('search');
    let activeCat = 'All';
    let query = '';

    function filter() {
      document.querySelectorAll('.post-card').forEach(card => {
        const cat = card.getAttribute('data-cat') || '';
        const text = card.textContent.toLowerCase();
        const catMatch = activeCat === 'All' || cat === activeCat;
        const searchMatch = !query || text.includes(query);
        card.style.display = (catMatch && searchMatch) ? '' : 'none';
      });
    }

    catCards.forEach(card => {
      card.addEventListener('click', () => {
        catCards.forEach(c => {
          c.classList.remove('bg-[#13342D]', 'text-[#E8E6E1]', 'border-[#13342D]');
          c.classList.add('bg-[#E8E6E1]', 'text-[#3F261F]', 'border-[#C8C4BC]');
        });
        card.classList.remove('bg-[#E8E6E1]', 'text-[#3F261F]', 'border-[#C8C4BC]');
        card.classList.add('bg-[#13342D]', 'text-[#E8E6E1]', 'border-[#13342D]');
        activeCat = card.getAttribute('data-cat') || 'All';
        if (activeCatEl) activeCatEl.textContent = activeCat === 'All' ? 'All desks' : activeCat;
        filter();
      });
    });
    searchEl?.addEventListener('input', () => { query = searchEl.value.toLowerCase(); filter(); });

    // Tabs
    const tabs = document.querySelectorAll('.tab-btn');
    const panels = document.querySelectorAll('.tab-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('text-[#3F261F]', 'border-[#13342D]');
          t.classList.add('text-[#8F6E62]', 'border-transparent');
        });
        tab.classList.remove('text-[#8F6E62]', 'border-transparent');
        tab.classList.add('text-[#3F261F]', 'border-[#13342D]');
        const target = tab.getAttribute('data-tab');
        panels.forEach(panel => {
          if (panel.getAttribute('data-panel') === target) {
            panel.classList.remove('hidden');
            panel.classList.add(target === 'trending' ? 'grid' : (target === 'latest' ? 'grid' : ''));
          } else {
            panel.classList.add('hidden');
            panel.classList.remove('grid');
          }
        });
      });
    });
  </script>
</BaseLayout>
