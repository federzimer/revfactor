  { href: '/blog-mockups/post-immersive', cat: 'Revenue Basics', date: 'Apr 12, 2026', read: '7 min', title: 'The quiet math of midweek shoulder season', img: 'https://images.unsplash.com/photo-1449844908441-8829872d2607?auto=format&fit=crop&w=1000&q=80' },
