        <div class="mt-16 p-8 rounded-[16px] bg-[#E8E6E1] border border-[#C8C4BC] flex gap-6 items-start flex-wrap md:flex-nowrap">
          <div class="w-16 h-16 rounded-full bg-[#13342D] flex items-center justify-center text-[#E8E6E1] font-bold text-[18px] flex-shrink-0" style="font-family:'Cormorant Garamond',Georgia,serif;">FZ</div>
