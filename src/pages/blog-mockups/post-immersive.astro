---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.jsx';
import Footer from '../../components/Footer.jsx';

const toc = [
  { href: '#sec-why-midweek',  label: 'Why midweek is different' },
  { href: '#sec-the-math',     label: 'The pricing floor math' },
  { href: '#sec-recovery',     label: 'Recovery playbook' },
  { href: '#sec-faq',          label: 'Frequently asked' },
];

const related = [
  { href: '/blog-mockups/post-classic',   cat: 'Pricing Strategy', date: 'Apr 18', read: '9 min',  title: 'The rate elasticity map of the Smoky Mountains',        img: 'https://images.unsplash.com/photo-1502784444187-359ac186c5bb?auto=format&fit=crop&w=1000&q=80' },
  { href: '/blog-mockups/post-split',     cat: 'Client Results',   date: 'Mar 19', read: '8 min',  title: 'How Blueridge Retreats added $184K in 11 months',       img: 'https://images.unsplash.com/photo-1482192596544-9eb780fc7f66?auto=format&fit=crop&w=1000&q=80' },
  { href: '/blog-mockups/post-classic',   cat: 'Market Data',      date: 'Feb 15', read: '6 min',  title: 'ADR vs. occupancy: stop choosing',                      img: 'https://images.unsplash.com/photo-1470770841072-f978cf4d019e?auto=format&fit=crop&w=1000&q=80' },
];
---

<BaseLayout
  title="The Quiet Math of Midweek Shoulder Season — The Curve"
  description="Tuesdays are where cabins get written off. 90 days of mid-market listings to find the pricing floor that pays."
  type="article"
  publishedTime="2026-04-12T00:00:00Z"
  author="Federico Zimerman"
>
  <Navbar client:load />

  <div id="progressBar" class="fixed top-0 left-0 h-[3px] bg-[#A9BBA3] z-[100] transition-[width] duration-75" style="width:0;"></div>

  <article>
    <!-- IMMERSIVE FULL-BLEED HERO -->
    <section class="relative overflow-hidden text-[#E8E6E1]" style="height:100vh; min-height:680px;">
      <div id="heroBg" class="absolute inset-0 will-change-transform bg-cover bg-center" style="background-image:url('https://images.unsplash.com/photo-1542718610-a1d656d1884c?auto=format&fit=crop&w=2400&q=85'); transform:scale(1.08);"></div>
      <div class="absolute inset-0 z-[1]" style="background: linear-gradient(180deg, rgba(22,25,16,0.5) 0%, rgba(22,25,16,0.15) 30%, rgba(22,25,16,0.2) 60%, rgba(22,25,16,0.9) 100%);"></div>

      <div class="relative z-[2] max-w-7xl mx-auto px-6 md:px-12 h-full flex flex-col justify-end pb-20 pt-36">
        <span class="font-bold uppercase text-[9px] tracking-[3px] text-[#A9BBA3] mb-6 inline-block">Revenue Basics · Field Report</span>
        <h1 class="text-[#E8E6E1] mb-8" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(56px,9vw,140px); line-height:0.9; letter-spacing:-1.5px; max-width:1100px;">
          the quiet math of<br/><em style="font-style:italic; color:#A9BBA3; font-weight:300;">midweek shoulder season.</em>
        </h1>
        <p class="mb-10 max-w-2xl" style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-weight:300; font-size:clamp(20px,2.2vw,28px); color:rgba(221,218,211,0.9); line-height:1.35;">
          Tuesdays are where cabins get written off. 90 days of mid-market listings to find the pricing floor that pays.
        </p>
        <div class="flex gap-12 flex-wrap pt-7 border-t border-[#DDDAD3]/25" style="font-family:'JetBrains Mono',monospace; font-size:11px; color:rgba(221,218,211,0.7); letter-spacing:0.5px; text-transform:uppercase;">
          <div>
            <div class="font-bold uppercase text-[9.5px] tracking-[2px] text-[#E8E6E1] mb-1.5" style="font-family:inherit;">Published</div>
            <div>Apr 12, 2026</div>
          </div>
          <div>
            <div class="font-bold uppercase text-[9.5px] tracking-[2px] text-[#E8E6E1] mb-1.5" style="font-family:inherit;">Read time</div>
            <div>7 minutes</div>
          </div>
          <div>
            <div class="font-bold uppercase text-[9.5px] tracking-[2px] text-[#E8E6E1] mb-1.5" style="font-family:inherit;">Sample</div>
            <div>820 midweek nights</div>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-[#DDDAD3]/20 backdrop-blur-sm flex items-center justify-center text-[#E8E6E1] font-bold text-[12px]" style="font-family:'Cormorant Garamond',Georgia,serif;">FZ</div>
            <div>
              <div class="text-[18px] text-[#E8E6E1] lowercase" style="font-family:'Cormorant Garamond',Georgia,serif;">federico zimerman</div>
              <div class="font-bold uppercase text-[9px] tracking-[2px] text-[#DDDAD3]/70">Founder · RevFactor</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BODY + right-rail TOC -->
    <div class="max-w-6xl mx-auto px-6 md:px-12 grid md:grid-cols-[1fr_240px] gap-16 md:gap-20 py-20">
      <div class="max-w-2xl min-w-0 ml-auto">

        <p class="prose-body first-letter:float-left first-letter:text-[72px] first-letter:leading-[0.9] first-letter:mr-3 first-letter:mt-2 first-letter:text-[#5D6D59]">
          <strong>Tuesday, March 4th</strong>, 7 p.m. A two-bedroom cabin in Pigeon Forge — three bedrooms, hot tub, 4.93 rating — sits at $89 a night. The calendar has 14 empty weeknights before the weekend. The host is about to make $89 × 0 across all of them.
        </p>

        <p class="prose-body">This is the quiet economics of midweek shoulder season. It's where cabins get written off in spreadsheets, where operators stop thinking about revenue and start thinking about "just covering the cleaning fee." It's also where the math is most interesting — because the floor most hosts set is far too low.</p>

        <section id="sec-why-midweek">
          <h2 class="prose-h2">Why Midweek Is Different</h2>
          <p class="prose-body">Weekend demand and weekday demand are not the same market. They share a calendar and a cleaning team, but the guests are different, the booking windows are different, and the price elasticity is different. Treating them with the same pricing rule — which most PMS defaults do — is the single biggest revenue leak we see in operator portfolios.</p>

          <figure class="my-10">
            <img src="https://images.unsplash.com/photo-1449844908441-8829872d2607?auto=format&fit=crop&w=2000&q=85" alt="" class="w-full rounded-[16px]" />
            <figcaption class="text-[13px] text-[#8F6E62] text-center mt-3" style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic;">Shoulder-season midweeks — the market's quietest economics. Lower demand doesn't mean lower elasticity.</figcaption>
          </figure>

          <p class="prose-body">Weekday guests in shoulder season are overwhelmingly one of three cohorts: remote workers on "workation," retirees on long stays, and business-adjacent travel. None of them shop price the same way as the Friday-to-Sunday leisure crowd. Remote workers care more about wifi than $20. Retirees book 28+ days out and barely look at last-minute rates.</p>
        </section>

        <section id="sec-the-math">
          <h2 class="prose-h2">The Pricing Floor Math</h2>
          <p class="prose-body">Here's the counterintuitive finding. Across our sample, lowering midweek rates by 20% below the competitive set's median lifted occupancy by only 6 percentage points — but lifted RevPAR by none.</p>

          <aside class="my-10 border-l-4 border-[#5D6D59] pl-6 py-4">
            <p class="text-[28px] leading-[1.2] text-[#3F261F] mb-4" style="font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-weight:300;">
              $89 occupied still beats $149 empty — until it doesn't.
            </p>
            <cite class="font-bold uppercase text-[10px] tracking-[2px] text-[#8F6E62] not-italic">— The old rule. We retired it.</cite>
          </aside>

          <p class="prose-body">The critical question isn't "will this book at $89?" — it's "will this book at $129 instead of $89, and are the 23% of guests who'd only book at $89 worth the 40% revenue haircut on the other 77%?" For most mid-market cabins in the Smokies sample: no.</p>

          <div class="grid grid-cols-3 gap-4 my-10 p-6 rounded-[16px] bg-[#5D6D59]/10 border border-[#5D6D59]/20">
            {[['+6pt', 'Occupancy lift from 20% discount'], ['$0', 'RevPAR lift from same move'], ['23%', 'Guests lost from $40 increase']].map(([num, label]) => (
              <div class="text-center">
                <div class="text-[#13342D] mb-1.5" style="font-family:'JetBrains Mono',monospace; font-weight:500; font-size:clamp(22px,3vw,32px);">{num}</div>
                <div class="font-bold uppercase text-[8.5px] tracking-[1.5px] text-[#5D6D59]">{label}</div>
              </div>
            ))}
          </div>
        </section>

        <section id="sec-recovery">
          <h2 class="prose-h2">The Midweek Recovery Playbook</h2>
          <p class="prose-body">What worked across the RevFactor portfolio this shoulder season:</p>
          <ol class="prose-ol">
            <li><strong>Minimum stay flexibility</strong> — drop from 3-night to 1-night minimum on Tuesday and Wednesday only. Most competitors stay locked at 3 nights.</li>
            <li><strong>Length-of-stay discounts on the right days</strong> — 20% off Tuesday/Wednesday rates, but ONLY when booked as part of a 4+ night stay. Boosts pacing without eroding weekend rates.</li>
            <li><strong>Event forecasting</strong> — midweek isn't dead everywhere. Track local events (concerts, games, conferences) 60 days out. The Friday concert pulls demand forward to Wednesday.</li>
          </ol>
          <p class="prose-body">The operators doing this are routinely capturing 15–20% more revenue per shoulder-season week than the set-and-forget crowd — without lowering their weekend premium.</p>
        </section>

        <section id="sec-faq">
          <h2 class="prose-h2">Frequently Asked</h2>
          <div class="space-y-3 mt-6">
            {[
              ['Does this apply to urban markets?', 'Directionally yes, with different absolute numbers. Urban midweek demand is usually stronger (business travel) but less elastic to length-of-stay discounts.'],
              ['What minimum stay rule would you set Monday morning?', 'For most mid-market cabins: 1 night Tue/Wed, 2 nights Thu/Sun, 3 nights Fri/Sat during shoulder. Tighten the weekend in peak.'],
              ['How do I know if I\'m underpricing midweek?', 'Pull your last 90 days of midweek occupancy. If you\'re above 60% and your rate is below the 40th percentile of comps, you\'re leaving money on the table.'],
            ].map(([q, a]) => (
              <details class="faq-item group rounded-[12px] border border-[#C8C4BC] bg-white/40 overflow-hidden">
                <summary class="flex items-center justify-between gap-4 cursor-pointer list-none px-5 py-4 hover:bg-white/70 transition-colors">
                  <span class="text-[16px] text-[#3F261F]" style="font-family:'Cormorant Garamond',Georgia,serif;">{q}</span>
                  <svg class="w-3.5 h-3.5 text-[#3F261F] transition-transform group-open:rotate-45 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                </summary>
                <div class="px-5 pb-5 text-[14px] leading-[1.6] text-[#76574C]">{a}</div>
              </details>
            ))}
          </div>
        </section>

        <div class="mt-16 p-8 rounded-[16px] bg-[#E8E6E1] border border-[#C8C4BC] flex gap-6 items-start flex-wrap md:flex-nowrap">
          <div class="w-16 h-16 rounded-full bg-[#13342D] flex items-center justify-center text-[#E8E6E1] font-bold text-[18px] flex-shrink-0" style="font-family:'Cormorant Garamond',Georgia,serif;">FZ</div>
          <div>
            <h4 class="text-[22px] text-[#3F261F] mb-1" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">federico zimerman</h4>
            <div class="font-bold uppercase text-[9px] tracking-[2px] text-[#8F6E62] mb-4">Founder · RevFactor</div>
            <p class="text-[14px] leading-[1.6] text-[#76574C] mb-4">Federico spent 10 years in airline revenue management before applying those principles to short-term rentals. RevFactor's pricing strategies are battle-tested across 165+ properties in 24 states.</p>
            <div class="flex gap-2">
              <a href="https://www.linkedin.com/in/federico-zimerman-23ab3345/" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-full border border-[#C8C4BC] text-[11px] font-bold uppercase tracking-[1.5px] text-[#3F261F] hover:border-[#3F261F] transition-colors">Follow on LinkedIn</a>
              <a href="/journal" class="px-3 py-1.5 rounded-full border border-[#C8C4BC] text-[11px] font-bold uppercase tracking-[1.5px] text-[#3F261F] hover:border-[#3F261F] transition-colors">More essays</a>
            </div>
          </div>
        </div>
      </div>

      <aside class="md:sticky md:top-24 md:self-start md:pl-6 md:border-l border-[#C8C4BC]">
        <h5 class="font-bold uppercase text-[9px] tracking-[2.5px] text-[#8F6E62] mb-4">In this essay</h5>
        <ul class="space-y-2.5" id="toc">
          {toc.map((item, i) => (
            <li>
              <a href={item.href} class="toc-link block text-[13px] leading-[1.4] text-[#76574C] hover:text-[#13342D] transition-colors">
                <span class="inline-block w-5 text-[#C8C4BC] mr-1" style="font-family:'JetBrains Mono',monospace;">{String(i + 1).padStart(2, '0')}</span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    </div>

    <!-- Related -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 pb-24">
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <div>
          <span class="font-bold uppercase text-[9px] tracking-[3px] text-[#8F6E62] mb-2 block">Keep reading</span>
          <h2 class="text-[#3F261F]" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400; font-size:clamp(28px,3.5vw,40px);">More <em style="font-style:italic; color:#7A8B76;">from The Curve.</em></h2>
        </div>
        <a href="/journal" class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[2px] text-[#3F261F] hover:text-[#13342D] transition-colors">
          All field notes
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {related.map(p => (
          <a href={p.href} class="group block">
            <div class="relative overflow-hidden rounded-[12px] mb-4" style="aspect-ratio:4/3;">
              <span class="absolute top-3 left-3 z-[2] px-2.5 py-1 rounded-full bg-[#E8E6E1]/92 text-[#3F261F] font-bold uppercase text-[9px] tracking-[2px] backdrop-blur-sm">{p.cat}</span>
              <img src={p.img} alt="" class="w-full h-full object-cover transition-transform duration-[600ms] group-hover:scale-[1.04]"/>
            </div>
            <div class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-[1.5px] text-[#8F6E62] mb-2">
              <span>{p.date}</span><span>·</span><span>{p.read}</span>
            </div>
            <h3 class="text-[20px] leading-[1.15] text-[#3F261F] group-hover:text-[#13342D] transition-colors" style="font-family:'Cormorant Garamond',Georgia,serif; font-weight:400;">{p.title}</h3>
          </a>
        ))}
      </div>
    </section>
  </article>

  <Footer client:load />

  <div class="fixed bottom-6 right-6 z-[60] bg-[#161910] text-[#E8E6E1] rounded-full px-2 py-1.5 flex items-center gap-1 shadow-xl text-[11px]">
    <span class="px-2 text-[#DDDAD3]/60 uppercase tracking-[1.5px] font-bold text-[9px]">Post</span>
    <a href="/blog-mockups/post-classic"   class="px-3 py-1.5 rounded-full hover:bg-[#E8E6E1]/10 font-bold uppercase text-[9px] tracking-[1.5px]">A · Classic</a>
    <a href="/blog-mockups/post-immersive" class="px-3 py-1.5 rounded-full bg-[#E8E6E1] text-[#161910] font-bold uppercase text-[9px] tracking-[1.5px]">B · Immersive</a>
    <a href="/blog-mockups/post-split"     class="px-3 py-1.5 rounded-full hover:bg-[#E8E6E1]/10 font-bold uppercase text-[9px] tracking-[1.5px]">C · Split</a>
    <span class="mx-1 w-px h-5 bg-[#E8E6E1]/20"></span>
    <a href="/journal" class="px-3 py-1.5 rounded-full hover:bg-[#E8E6E1]/10 font-bold uppercase text-[9px] tracking-[1.5px]">← Index</a>
  </div>

  <style>
    .prose-body { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 19px; line-height: 1.65; color: #3F261F; margin: 0 0 1.5em; }
    .prose-h2   { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: clamp(28px, 3.5vw, 40px); line-height: 1.15; color: #3F261F; margin: 2.5em 0 0.75em; letter-spacing: -0.25px; }
    .prose-ol, .prose-ul { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 18px; line-height: 1.65; color: #3F261F; padding-left: 1.5em; margin: 0 0 1.5em; }
    .prose-ol li, .prose-ul li { margin-bottom: 0.6em; }
    .prose-ol { list-style: decimal; }
    .prose-ul { list-style: disc; }
    .prose-body strong, .prose-ol strong { color: #13342D; font-weight: 600; }
    .prose-body em { color: #5D6D59; font-style: italic; }
    .toc-link.active { color: #13342D; font-weight: 600; }
  </style>

  <script>
    const bar = document.getElementById('progressBar');
    const article = document.querySelector('article');
    const heroBg = document.getElementById('heroBg');
    window.addEventListener('scroll', () => {
      if (article && bar) {
        const rect = article.getBoundingClientRect();
        const total = article.offsetHeight - window.innerHeight;
        const scrolled = -rect.top;
        const pct = Math.max(0, Math.min(100, (scrolled / total) * 100));
        bar.style.width = pct + '%';
      }
      if (heroBg) {
        const y = window.scrollY;
        if (y < 1000) heroBg.style.transform = `scale(1.08) translateY(${y * 0.25}px)`;
      }
    }, { passive: true });

    const tocLinks = document.querySelectorAll('.toc-link');
    const sections = Array.from(tocLinks).map(a => document.querySelector(a.getAttribute('href')));
    function updateTOC() {
      const y = window.scrollY + 200;
      let activeIdx = 0;
      sections.forEach((sec, i) => { if (sec && sec.offsetTop <= y) activeIdx = i; });
      tocLinks.forEach((l, i) => l.classList.toggle('active', i === activeIdx));
    }
    window.addEventListener('scroll', updateTOC, { passive: true });
    updateTOC();
  </script>
</BaseLayout>
